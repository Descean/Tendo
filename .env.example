# === Database ===
# SQLite (dev local – par défaut)
DATABASE_URL=sqlite+aiosqlite:///./tendo.db
DATABASE_URL_SYNC=sqlite:///./tendo.db
# PostgreSQL (production – décommenter)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tendo
# DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/tendo

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === WhatsApp Provider ===
# "meta" = Meta Cloud API (GRATUIT, 1000 conv/mois) — recommandé
# "twilio" = Twilio (payant)
WHATSAPP_PROVIDER=meta

# Meta WhatsApp Cloud API (GRATUIT)
META_PHONE_NUMBER_ID=your_phone_number_id
META_ACCESS_TOKEN=your_meta_access_token
META_VERIFY_TOKEN=tendo_verify_token_2024
META_APP_SECRET=your_app_secret
META_BUSINESS_ACCOUNT_ID=your_business_account_id

# Twilio (OPTIONNEL, payant)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# === Claude AI (Anthropic) ===
# Gemini (GRATUIT — par défaut, 15 req/min, 1M tokens/jour)
# Obtenir une clé: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Claude (PREMIUM — optionnel, pour abonnés premium)
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === FedaPay (Mobile Money MTN/Moov – Bénin) ===
# Créer un compte sur https://fedapay.com
# Mode sandbox (test) : clé commence par sk_sandbox_
# Mode live : clé commence par sk_live_
FEDAPAY_SECRET_KEY=sk_sandbox_xxxxxxxxxxxxxxxxxxxxxxxx
FEDAPAY_PUBLIC_KEY=pk_sandbox_xxxxxxxxxxxxxxxxxxxxxxxx
FEDAPAY_WEBHOOK_SECRET=your_webhook_secret

# === Email (SMTP/IMAP) ===
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tendo@example.com
SMTP_PASSWORD=your_smtp_password
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993

# === Security ===
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === Scraping ===
SCRAPING_SCHEDULE=0 6 * * *

# === Admin ===
ADMIN_EMAILS=["admin@shiftup.bj"]

# === App ===
APP_NAME=Tendo
APP_ENV=development
APP_DEBUG=true
BASE_URL=https://tendo.shiftup.bj
